<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <!-- Unique identifier of the plugin. It should be FQN. It cannot be changed between the plugin versions. -->
    <id>org.dotykacka.xcp-extension-plugin</id>

    <!-- Public plugin name should be written in Title Case.
     Guidelines: https://plugins.jetbrains.com/docs/marketplace/best-practices-for-listing.html#plugin-name -->
    <name>1CLICK XCP Support</name>

    <!-- A displayed Vendor name or Organization ID displayed on the Plugins Page. -->
    <vendor>Dotykacka</vendor>

    <!-- Description of the plugin displayed on the Plugin Page and IDE Plugin Manager.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/best-practices-for-listing.html#plugin-description -->
    <description><![CDATA[
        Editor support for 1CLICK <code>.xcp</code> process definition files.
        Provides file type association, syntax highlighting, comment toggling,
        brace matching, reference-manual based completions, and basic process schema validation.
        ]]></description>

    <!-- Product and plugin compatibility requirements.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html -->
    <depends>com.intellij.modules.platform</depends>

    <resource-bundle>messages.MyMessageBundle</resource-bundle>

    <!-- Extensions defined by the plugin.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-extension-points.html -->
    <extensions defaultExtensionNs="com.intellij">
        <fileType name="XCP Process"
                  language="XCP"
                  implementationClass="org.dotykacka.xcp.XcpFileType"
                  fieldName="INSTANCE"
                  extensions="xcp"/>
        <lang.parserDefinition language="XCP"
                               implementationClass="org.dotykacka.xcp.XcpParserDefinition"/>
        <lang.syntaxHighlighterFactory language="XCP"
                                       implementationClass="org.dotykacka.xcp.XcpSyntaxHighlighterFactory"/>
        <lang.commenter language="XCP"
                        implementationClass="org.dotykacka.xcp.XcpCommenter"/>
        <lang.braceMatcher language="XCP"
                           implementationClass="org.dotykacka.xcp.XcpBraceMatcher"/>
        <lang.findUsagesProvider language="XCP"
                                 implementationClass="org.dotykacka.xcp.XcpFindUsagesProvider"/>
        <findUsagesHandlerFactory implementationClass="org.dotykacka.xcp.XcpFindUsagesHandlerFactory"/>
        <highlightUsagesHandlerFactory implementationClass="org.dotykacka.xcp.XcpHighlightUsagesHandlerFactory"/>
        <gotoDeclarationHandler implementationClass="org.dotykacka.xcp.XcpGotoDeclarationHandler"/>
        <annotator language="XCP"
                   implementationClass="org.dotykacka.xcp.XcpAnnotator"/>
        <localInspection language="XCP"
                         shortName="XcpSchema"
                         displayName="1CLICK XCP schema validation"
                         groupName="1CLICK XCP"
                         enabledByDefault="true"
                         level="WARNING"
                         implementationClass="org.dotykacka.xcp.XcpInspection"/>
        <completion.contributor language="XCP"
                                implementationClass="org.dotykacka.xcp.XcpCompletionContributor"/>
        <psi.referenceContributor language="XCP"
                                  implementation="org.dotykacka.xcp.XcpReferenceContributor"/>
    </extensions>

</idea-plugin>
